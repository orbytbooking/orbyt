# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe (use test keys for development; never commit real keys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Platform (Orbyt) subscription — Starter / Growth / Premium (optional if set in platform_subscription_plans.stripe_price_id)
# STRIPE_PLATFORM_PRICE_STARTER=price_xxx
# STRIPE_PLATFORM_PRICE_GROWTH=price_xxx
# STRIPE_PLATFORM_PRICE_PREMIUM=price_xxx
# Legacy: STRIPE_PLATFORM_PRICE_PRO and STRIPE_PLATFORM_PRICE_ENTERPRISE still map to Growth / Premium

# Platform billing provider: default is authorize_net (workspace plans). Set stripe to use Stripe Checkout + Customer Portal instead.
# PLATFORM_BILLING_PROVIDER=stripe
# Orbyt merchant account (separate from each tenant’s Authorize.Net keys in admin Billing)
# PLATFORM_AUTHORIZE_NET_API_LOGIN_ID=
# PLATFORM_AUTHORIZE_NET_TRANSACTION_KEY=
# production = api.authorize.net + accept.authorize.net; omit = sandbox apitest + test.authorize.net (no real charges).
# You can use sandbox keys with NEXT_PUBLIC_APP_URL=https://your-live-site.com so return/cancel hit production after test payments.
# AUTHORIZE_NET_ENVIRONMENT=production

# Worldpay Access Hosted Payments (POST /payment_pages)
# Default: Bearer auth + WP-Entity-Id. If you get 401 "Invalid authentication", try Basic auth (official doc uses Basic).
# WORLD_PAY_SERVICE_KEY=your_service_key
# WORLDPAY_ENTITY=your_entity_from_dashboard
# Optional: WORLDPAY_ACCOUNT_TOKEN instead of WORLD_PAY_SERVICE_KEY
# If Bearer fails 401, use Basic (from Implementation Manager): WORLDPAY_USE_BASIC_AUTH=true and WORLDPAY_BASIC_AUTH=<Base64 of "username:password">
# WORLDPAY_BASE_URL=https://try.access.worldpay.com
# Live: https://access.worldpay.com

# OpenAI (for AI receptionist chat)
# OPENAI_API_KEY=sk-your_openai_api_key

# App — must match the browser origin users use (https in production). Authorize.Net hosted checkout rejects hostname "localhost"; use 127.0.0.1 for local.
# Production example: NEXT_PUBLIC_APP_URL=https://www.yourdomain.com
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Google Calendar (OAuth for syncing bookings to Google Calendar)
# Create a project in Google Cloud Console, enable Google Calendar API, create OAuth 2.0 credentials (Web application).
# Authorized redirect URI must match GOOGLE_CALENDAR_REDIRECT_URI exactly (e.g. http://localhost:3000/api/admin/integrations/google-calendar/callback).
# GOOGLE_CALENDAR_CLIENT_ID=your_client_id.apps.googleusercontent.com
# GOOGLE_CALENDAR_CLIENT_SECRET=your_client_secret
# GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/admin/integrations/google-calendar/callback

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
