# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe (use test keys for development; never commit real keys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Worldpay Access Hosted Payments (POST /payment_pages)
# Default: Bearer auth + WP-Entity-Id. If you get 401 "Invalid authentication", try Basic auth (official doc uses Basic).
# WORLD_PAY_SERVICE_KEY=your_service_key
# WORLDPAY_ENTITY=your_entity_from_dashboard
# Optional: WORLDPAY_ACCOUNT_TOKEN instead of WORLD_PAY_SERVICE_KEY
# If Bearer fails 401, use Basic (from Implementation Manager): WORLDPAY_USE_BASIC_AUTH=true and WORLDPAY_BASIC_AUTH=<Base64 of "username:password">
# WORLDPAY_BASE_URL=https://try.access.worldpay.com
# Live: https://access.worldpay.com

# OpenAI (for AI receptionist chat)
# OPENAI_API_KEY=sk-your_openai_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
